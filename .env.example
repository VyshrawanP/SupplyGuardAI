## SupplyGuardAI env (example)
## Copy to `.env` and fill values as needed.

## ------------------------------------------------------------
## Core project
## ------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
OFFLINE_MODE=true

## Vite client flag (used by the web console)
VITE_OFFLINE_MODE=true

## ------------------------------------------------------------
## Firebase / Google Cloud (server-side)
## ------------------------------------------------------------
# Used by backend services that use firebase-admin / PubSub.
GOOGLE_CLOUD_PROJECT_ID=
FIREBASE_PROJECT_ID=

# For local dev you can point to a service account JSON:
GOOGLE_APPLICATION_CREDENTIALS=

## ------------------------------------------------------------
## API Gateway (CORS)
## ------------------------------------------------------------
FLUTTER_WEB_ORIGIN=http://localhost:5173

## Downstream service URLs (local defaults shown)
INGESTION_SERVICE_URL=http://localhost:3001
RISK_ENGINE_URL=http://localhost:3002
ROUTE_OPTIMIZER_URL=http://localhost:3003
DRONE_ENGINE_URL=http://localhost:3004
RESCUE_ENGINE_URL=http://localhost:3005
INVENTORY_ENGINE_URL=http://localhost:3006
ANOMALY_ENGINE_URL=http://localhost:3007
AI_EXPLAINER_URL=http://localhost:3008
SIMULATION_ENGINE_URL=http://localhost:3009

## ------------------------------------------------------------
## External data sources (optional; used by ingestion/optimizer)
## ------------------------------------------------------------
OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DIRECTIONS_API_KEY=
GOOGLE_MAPS_ELEVATION_API_KEY=

## ------------------------------------------------------------
## Pub/Sub topics (optional; defaults used if empty)
## ------------------------------------------------------------
PUBSUB_DISASTER_SIGNALS_TOPIC=disaster-signals
PUBSUB_RISK_DECISIONS_TOPIC=risk-decisions
PUBSUB_ROUTE_UPDATES_TOPIC=route-updates
PUBSUB_ALERTS_TOPIC=alerts
PUBSUB_INVENTORY_EVENTS_TOPIC=inventory-events

## ------------------------------------------------------------
## Messaging (optional)
## ------------------------------------------------------------
GEMINI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=

## ------------------------------------------------------------
## Offline stack tuning (optional)
## ------------------------------------------------------------
LOCAL_OSRM_URL=http://localhost:5000
LOCAL_TILESERVER_URL=http://localhost:8080
VITE_LOCAL_OSRM_URL=http://localhost:5000
VITE_LOCAL_TILESERVER_URL=http://localhost:8080
VITE_TILE_STYLE=basic
## Optional override (full Leaflet template):
## VITE_TILE_URL_TEMPLATE=http://localhost:8080/styles/basic/{z}/{x}/{y}.png
LOCAL_SERVER_IP=
CONNECTIVITY_PING_URL=8.8.8.8

## ------------------------------------------------------------
## Model/service tuning (optional)
## ------------------------------------------------------------
DRONE_MAX_RANGE_KM=15
DELAY_ANOMALY_THRESHOLD_PERCENT=40
TEAM_SILENCE_ALERT_MINUTES=30
