# --- Vercel Environment Variables ---
# Add these in Vercel Dashboard > Settings > Environment Variables

# [Backend] Gemini API Key (Secret)
# Use this for server-side insights. Keep this secret!
GEMINI_API_KEY=your_gemini_api_key_here

# [Frontend] Google Maps API Key (Public)
# Prefixed with VITE_ to be bundled by Vite.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# [Backend] Other Google Maps Keys (Secret)
# If your backend uses them for directions/elevation.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_DIRECTIONS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_ELEVATION_API_KEY=your_google_maps_api_key_here
