rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Demo-friendly admin check:
      // - for real deployments, rely on custom claims or a hardened role model.
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /shipments/{shipmentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated(); // For demo purposes, allow authenticated users to update
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isAuthenticated(); // Allow simulation for demo
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isAuthenticated();
    }

    // Public read for demo (judge-visible) hospital capacity.
    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write: if isAdmin();

      match /capacity/{capacityDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
